<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="420.0" prefWidth="560.0" spacing="18.0" style="-fx-background-color: #f5f7fb;" xmlns="http://javafx.com/javafx/17.0.10" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.ViewController.EmpresaViewController">
    <children>
        <Label text="Gestion de Empresa">
            <font>
                <Font name="System Bold" size="25.0" />
            </font>
        </Label>

        <GridPane hgap="12.0" vgap="12.0">
            <children>
                <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtNombreEmpresa" prefWidth="260.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Cantidad empleados:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Label fx:id="lblCantidadEmpleados" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Nomina total:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Label fx:id="lblNominaTotal" text="0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Mayor salario:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Label fx:id="lblMayorSalario" text="Sin empleados" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </children>
        </GridPane>

        <Button mnemonicParsing="false" onAction="#onActualizarEmpresa" prefWidth="180.0" text="Actualizar empresa" />
        <Button mnemonicParsing="false" onAction="#onOpenCrudEmpleado" prefWidth="180.0" text="Registrar empleado" />
        <Button mnemonicParsing="false" onAction="#onVolverMenu" prefWidth="180.0" text="Volver al menu" />
    </children>
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
</VBox>
