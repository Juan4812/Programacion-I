<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="520.0" prefWidth="760.0" style="-fx-background-color: #eef2f7;" xmlns="http://javafx.com/javafx/17.0.10" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.ViewController.MenuViewController">
    <top>
        <VBox spacing="6.0" style="-fx-background-color: #243447;">
            <padding>
                <Insets bottom="20.0" left="28.0" right="28.0" top="22.0" />
            </padding>
            <children>
                <Label fx:id="lblNombreEmpresa" text="Empresa" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Label text="Menu principal" textFill="#d8dee9">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </top>
    <center>
        <GridPane alignment="CENTER" hgap="18.0" vgap="18.0">
            <children>
                <Button mnemonicParsing="false" onAction="#onAbrirEmpresa" prefHeight="70.0" prefWidth="210.0" style="-fx-font-size: 14px;" text="Empresa" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Button mnemonicParsing="false" onAction="#onRegistrarEmpleado" prefHeight="70.0" prefWidth="210.0" style="-fx-font-size: 14px;" text="Registrar empleado" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Button mnemonicParsing="false" onAction="#onEmpleadosRegistrados" prefHeight="70.0" prefWidth="210.0" style="-fx-font-size: 14px;" text="Empleados registrados" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Button mnemonicParsing="false" onAction="#onResumenPagos" prefHeight="70.0" prefWidth="210.0" style="-fx-font-size: 14px;" text="Resumen de pagos" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Button mnemonicParsing="false" onAction="#onConsultas" prefHeight="70.0" prefWidth="438.0" style="-fx-font-size: 14px;" text="Consultas" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="2" />
            </children>
        </GridPane>
    </center>
</BorderPane>
