<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="620.0" prefWidth="900.0" style="-fx-background-color: #f5f7fb;" xmlns="http://javafx.com/javafx/17.0.10" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.ViewController.ResumenPagoViewController">
    <top>
        <BorderPane style="-fx-background-color: #243447;">
            <padding>
                <Insets bottom="12.0" left="18.0" right="18.0" top="12.0" />
            </padding>
            <left>
                <Label fx:id="lblNombreEmpresa" text="Empresa" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
            </left>
            <right>
                <Button mnemonicParsing="false" onAction="#onVolverMenu" text="Volver al menu" />
            </right>
        </BorderPane>
    </top>
    <center>
        <VBox spacing="14.0">
            <padding>
                <Insets bottom="24.0" left="26.0" right="26.0" top="24.0" />
            </padding>
            <children>
                <Label text="Resumen de pagos">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Button mnemonicParsing="false" onAction="#onActualizarResumen" text="Actualizar resumen" />
                <TextArea fx:id="txtResumenPagos" editable="false" prefHeight="440.0" prefWidth="840.0" promptText="Aqui apareceran los resumenes de pago" />
            </children>
        </VBox>
    </center>
</BorderPane>
